{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer created by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "FuelIndex": {
      "title": "FuelIndex",
      "description": "Weekly fuel index data",
      "type": "object",
      "properties": {
        "price": { "type": "number" },
        "source": { "type": "string" },
        "effectiveDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["price", "source", "effectiveDate", "createdAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "A fuel surcharge schedule configuration",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerId": { "type": "string" },
        "name": { "type": "string" },
        "baseRate": { "type": "number" },
        "baselineFuelPrice": { "type": "number" },
        "mpg": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerId", "name", "baseRate", "baselineFuelPrice", "mpg", "createdAt"]
    },
    "ScheduleSnapshot": {
      "title": "ScheduleSnapshot",
      "description": "A versioned snapshot of a schedule calculation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "scheduleId": { "type": "string" },
        "fuelIndexId": { "type": "string" },
        "surchargePerMile": { "type": "number" },
        "surchargePercentage": { "type": "number" },
        "adjustedRate": { "type": "number" },
        "effectiveDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "scheduleId", "fuelIndexId", "surchargePerMile", "surchargePercentage", "adjustedRate", "effectiveDate", "createdAt"]
    },
    "SkuProfile": {
      "title": "SkuProfile",
      "description": "Saved SKU profile for LTL Density Pro",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sku": { "type": "string" },
        "length": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "palletIncluded": { "type": "boolean" },
        "stackable": { "type": "boolean" },
        "packagingType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "sku", "length", "width", "height", "weight", "palletIncluded", "stackable", "createdAt"]
    },
    "ShipmentHistory": {
      "title": "ShipmentHistory",
      "description": "History of LTL calculations",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "length": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "units": { "type": "number" },
        "palletIncluded": { "type": "boolean" },
        "stackable": { "type": "boolean" },
        "packagingType": { "type": "string" },
        "density": { "type": "number" },
        "estimatedClass": { "type": "string" },
        "riskScore": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "length", "width", "height", "weight", "units", "palletIncluded", "stackable", "density", "estimatedClass", "riskScore", "createdAt"]
    },
    "MonitoredCarrier": {
      "title": "MonitoredCarrier",
      "description": "Carrier saved to a user's watchlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mcNumber": { "type": "string" },
        "dotNumber": { "type": "string" },
        "name": { "type": "string" },
        "riskScore": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mcNumber", "name", "riskScore", "status", "createdAt"]
    },
    "CarrierNote": {
      "title": "CarrierNote",
      "description": "User notes on specific carriers",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mcNumber": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mcNumber", "note", "createdAt"]
    },
    "LandedCostCalculation": {
      "title": "LandedCostCalculation",
      "description": "History of landed cost estimates",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productDescription": { "type": "string" },
        "originCountry": { "type": "string" },
        "destinationCountry": { "type": "string" },
        "productValue": { "type": "number" },
        "shippingCost": { "type": "number" },
        "hsCode": { "type": "string" },
        "dutyRate": { "type": "number" },
        "vatRate": { "type": "number" },
        "totalDuty": { "type": "number" },
        "totalVat": { "type": "number" },
        "landedCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productDescription", "originCountry", "destinationCountry", "productValue", "shippingCost", "hsCode", "dutyRate", "vatRate", "totalDuty", "totalVat", "landedCost", "createdAt"]
    },
    "SavedProduct": {
      "title": "SavedProduct",
      "description": "User's saved product catalog for landed costs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "hsCode": { "type": "string" },
        "dutyRate": { "type": "number" },
        "vatRate": { "type": "number" },
        "originCountry": { "type": "string" },
        "destinationCountry": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "description", "hsCode", "dutyRate", "vatRate", "originCountry", "destinationCountry", "createdAt"]
    },
    "DnDAudit": {
      "title": "DnDAudit",
      "description": "History of D&D audits",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "containerNumber": { "type": "string" },
        "availabilityDate": { "type": "string" },
        "pickupDate": { "type": "string" },
        "freeTimeDays": { "type": "number" },
        "billedDays": { "type": "number" },
        "dailyRate": { "type": "number" },
        "totalBilled": { "type": "number" },
        "isValid": { "type": "boolean" },
        "estimatedOvercharge": { "type": "number" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "containerNumber", "availabilityDate", "pickupDate", "freeTimeDays", "billedDays", "dailyRate", "totalBilled", "isValid", "estimatedOvercharge", "issues", "createdAt"]
    },
    "3plLead": {
      "title": "3plLead",
      "description": "Lead generated by the 3PL Matchmaker",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "requirements": { "type": "object" },
        "matchedProviders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "requirements", "matchedProviders", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Customers managed by users"
    },
    "/fuel_index/{fuelIndexId}": {
      "schema": { "$ref": "#/entities/FuelIndex" },
      "description": "Weekly fuel index records"
    },
    "/schedules/{scheduleId}": {
      "schema": { "$ref": "#/entities/Schedule" },
      "description": "Fuel surcharge schedules"
    },
    "/schedule_snapshots/{snapshotId}": {
      "schema": { "$ref": "#/entities/ScheduleSnapshot" },
      "description": "Historical snapshots of calculations"
    },
    "/sku_profiles/{skuId}": {
      "schema": { "$ref": "#/entities/SkuProfile" },
      "description": "Saved SKU profiles"
    },
    "/shipment_history/{historyId}": {
      "schema": { "$ref": "#/entities/ShipmentHistory" },
      "description": "History of LTL calculations"
    },
    "/monitored_carriers/{carrierId}": {
      "schema": { "$ref": "#/entities/MonitoredCarrier" },
      "description": "Carriers on user watchlists"
    },
    "/carrier_notes/{noteId}": {
      "schema": { "$ref": "#/entities/CarrierNote" },
      "description": "User notes for carriers"
    },
    "/landed_cost_history/{historyId}": {
      "schema": { "$ref": "#/entities/LandedCostCalculation" },
      "description": "History of landed cost estimates"
    },
    "/saved_products/{productId}": {
      "schema": { "$ref": "#/entities/SavedProduct" },
      "description": "Saved product catalog"
    },
    "/dnd_audits/{auditId}": {
      "schema": { "$ref": "#/entities/DnDAudit" },
      "description": "History of Detention & Demurrage audits"
    },
    "/3pl_leads/{leadId}": {
      "schema": { "$ref": "#/entities/3plLead" },
      "description": "Leads generated by the 3PL Matchmaker"
    }
  }
}
